# Скопируйте в .env и заполните. Файл .env в git не попадает (.gitignore).

# --- Подключение к VPS (для deploy.sh) ---
VPS_HOST=1.2.3.4              # IP или хостнейм VPS
VPS_USER=root                 # пользователь SSH
VPS_PORT=22                   # порт SSH
VPS_SSH_KEY=                  # путь к приватному ключу (пусто = ключ по умолчанию ~/.ssh/id_*)
VPS_APP_DIR=/opt/kydir        # куда кладём приложение на VPS

# --- Настройки приложения на VPS ---
REPO_URL=https://github.com/N-ov/KYDiR.git
DOMAIN=:80                    # домен для HTTPS (budget.example.com) или :80 для HTTP по IP
KYDIR_COOKIE_SECURE=0         # 1 если DOMAIN с HTTPS, 0 если просто HTTP по IP
KYDIR_SESSION_TTL_DAYS=30
